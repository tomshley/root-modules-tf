# Per-environment streaming credentials.
# Copy to staging-us-east-1-streaming.env and fill in the values.
# This file is sourced by the Makefile before init/plan/apply.

CONFLUENT_CLOUD_API_KEY=<confluent-cloud-api-key>
CONFLUENT_CLOUD_API_SECRET=<confluent-cloud-api-secret>

# Optional: point to a secure tfvars file for Confluent + workload config
SECURE_TFVARS_FILE=../../../../.secure_files/staging-us-east-1-streaming.tfvars
