# ------------------------------------------------------------------------------
# root-modules-tf – Secure Files Environment
# ------------------------------------------------------------------------------
# Copy to .env and fill in values as needed.
# This .env.example is SAFE to commit. The actual .env is gitignored (*.env).
#
# The cicd-pipelines adapter sources .secure_files/.env before toolbox-entry.sh
# runs. Variables set here are available to all pipeline jobs that use the
# bootstrap, git-push-config, or mirror-config chains.
#
# Reference: cicd-pipelines toolbox/VARIABLES.md
# ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# Git flow push auth (RECOMMENDED for tag-triggered publishing)
# ------------------------------------------------------------------------------
# On GitLab, CI_JOB_TOKEN pushes do NOT trigger downstream pipelines.
# Without a Project Access Token, gitflow finish jobs (release-finish,
# hotfix-finish) will push tags that silently skip the tag pipeline —
# meaning publish-terraform-modules will NOT run automatically.
#
# Create a Project Access Token with write_repository scope and set it
# as a masked CI/CD variable, or place it here in .env.
# ------------------------------------------------------------------------------

# GitLab Project Access Token with write_repository scope
# TOMSHLEY_CICD_FLOW_PUSH_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# Username for push auth (GitLab adapter defaults to "oauth2" — usually correct)
# TOMSHLEY_CICD_FLOW_PUSH_USER=oauth2

# ------------------------------------------------------------------------------
# Secrets bootstrap (OPTIONAL)
# ------------------------------------------------------------------------------
# Default: "true" — GitLab Secure Files installer runs before every job.
# Set to "false" to skip if not using GitLab Secure Files.
# ------------------------------------------------------------------------------

# TOMSHLEY_CICD_SECRETS_BOOTSTRAP=true
